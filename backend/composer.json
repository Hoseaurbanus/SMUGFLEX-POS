{
    "name": "smugflex/pos-backend",
    "description": "SmugFlex POS - Enterprise Point of Sale System API",
    "type": "project",
    "license": "proprietary",
    "minimum-stability": "stable",
    "require": {
        "php": "^8.2",
        "codeigniter4/framework": "^4.5",
        "firebase/php-jwt": "^6.10"
    },
    "require-dev": {
        "codeigniter4/settings": "^1.1",
        "codeigniter4/shield": "^1.2",
        "phpunit/phpunit": "^10.0",
        "fakerphp/faker": "^1.23"
    },
    "autoload": {
        "psr-4": {
            "App\\": "app/",
            "CodeIgniter\\": "vendor/codeigniter4/framework/system/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\Support\\": "tests/Support/"
        }
    },
    "config": {
        "process-timeout": 300,
        "fxp-composer": {
            "asset-installer-paths": {
                "npm-asset-library": "vendor/npm",
                "bower-asset-library": "vendor/bower"
            }
        },
        "preferred-install": "dist",
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true
        }
    },
    "scripts": {
        "test": "phpunit",
        "post-autoload-dump": [
            "CodeIgniter\\Composer\\Scripts::postAutoloadDump",
            "@php spark package:discover"
        ]
    },
    "extra": {
        "branch-alias": {
            "dev": "develop"
        }
    }
}
